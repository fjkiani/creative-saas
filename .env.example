# Creative Automation Pipeline v4 — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Authentication ────────────────────────────────────────────────────────────
# Set a strong random string to enable API key auth on all /api/* routes.
# Leave empty to disable auth (dev mode — a warning is logged at startup).
PIPELINE_API_KEY=

# ── Providers ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
IMAGE_PROVIDER=gemini
STORAGE_BACKEND=supabase   # supabase | local | s3 | azure | dropbox

# ── Parallelism ───────────────────────────────────────────────────────────────
IMAGE_GEN_CONCURRENCY=3

# ── HITL Threshold Valves ─────────────────────────────────────────────────────
HITL_AUTO_APPROVE=0.85
HITL_AUTO_REJECT=0.60

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://cllqahmtyvdcbyyrouxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy alias (either works):
# SUPABASE_SERVICE_KEY=

# ── v4: OpenRouter (canvas editor, competitor analysis, AI video) ──────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
EDIT_PROVIDER=gpt5          # gpt5 | gemini
VISION_PROVIDER=llama

# ── v4: Stripe (billing & subscriptions) ──────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=           # Price ID for $49/mo Pro plan
STRIPE_PRICE_AGENCY=        # Price ID for $199/mo Agency plan
STRIPE_PRICE_ENTERPRISE=    # Price ID for Enterprise plan

# ── v4: Instagram OAuth (Meta Graph API) ──────────────────────────────────────
# Get from: https://developers.facebook.com/apps/
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=https://your-backend.onrender.com/api/workspaces/callback/instagram

# ── v4: TikTok OAuth (Content Posting API v2) ─────────────────────────────────
# Get from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-backend.onrender.com/api/workspaces/callback/tiktok

# ── v4: Apify (competitor URL scraping) ───────────────────────────────────────
# Get from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Adobe Firefly (optional) ──────────────────────────────────────────────────
FIREFLY_CLIENT_ID=
FIREFLY_CLIENT_SECRET=

# ── Stability AI (optional) ───────────────────────────────────────────────────
STABILITY_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
