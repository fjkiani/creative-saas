# Creative Automation Pipeline v3 — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Authentication ────────────────────────────────────────────────────────────
# Set a strong random string to enable API key auth on all /api/* routes.
# Leave empty to disable auth (dev mode — a warning is logged at startup).
PIPELINE_API_KEY=

# ── Providers ─────────────────────────────────────────────────────────────────
# LLM provider: gemini | openai | anthropic
LLM_PROVIDER=gemini

# Image provider: gemini | dalle | firefly | stability
IMAGE_PROVIDER=gemini

# Storage backend: local | supabase | s3 | azure | dropbox
STORAGE_BACKEND=local

# ── Parallelism ───────────────────────────────────────────────────────────────
# Max concurrent image generation API calls (semaphore cap).
# Increase for faster generation; decrease if hitting rate limits.
IMAGE_GEN_CONCURRENCY=3

# ── HITL Threshold Valves ─────────────────────────────────────────────────────
# Compliance confidence score thresholds for the review_gate node.
# score >= HITL_AUTO_APPROVE → auto-approve, pipeline continues
# score <  HITL_AUTO_REJECT  → auto-reject, pipeline terminates
# between the two            → PENDING_REVIEW, human decision required
HITL_AUTO_APPROVE=0.85
HITL_AUTO_REJECT=0.60

# ── Supabase (optional — for Realtime + cloud storage) ────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── OpenAI (optional — if LLM_PROVIDER=openai or IMAGE_PROVIDER=dalle) ────────
OPENAI_API_KEY=

# ── Anthropic (optional — if LLM_PROVIDER=anthropic) ─────────────────────────
ANTHROPIC_API_KEY=

# ── Adobe Firefly (optional — if IMAGE_PROVIDER=firefly) ──────────────────────
FIREFLY_CLIENT_ID=
FIREFLY_CLIENT_SECRET=

# ── Stability AI (optional — if IMAGE_PROVIDER=stability) ─────────────────────
STABILITY_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for dev, restrict in production.
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_API_KEY=
